YUANTA_ACCOUNT=Sxxxxxxxxxxx
YUANTA_PASSWORD=your-trading-password
# 憑證請放在專案目錄外（如 ~/Desktop/Project/Stock_ptx），不要放進本 repo
YUANTA_CERT_PATH=/path/outside/repo/your-yuanta-cert.pfx
YUANTA_CERT_PASSWORD=your-pfx-password
YUANTA_ENV=UAT

# Query defaults
YUANTA_MARKET=TWSE
YUANTA_SYMBOL=2885
YUANTA_KLINE_TYPE=11
YUANTA_KLINE_START=2025/01/01
YUANTA_KLINE_END=2025/03/26

# Stock order defaults. Orders are disabled until YUANTA_ENABLE_ORDER=YES.
YUANTA_ENABLE_ORDER=NO
YUANTA_ORDER_SYMBOL=2885
YUANTA_ORDER_SIDE=B
YUANTA_ORDER_PRICE=35.0
YUANTA_ORDER_QTY=1
YUANTA_ORDER_PRICE_FLAG=M
YUANTA_ORDER_TYPE=0
YUANTA_ORDER_TRADE_KIND=0
YUANTA_ORDER_AP_CODE=0
YUANTA_ORDER_TIME_IN_FORCE=0

# SinoPac (永豐金) Shioaji — https://sinotrade.github.io/
SHIOAJI_API_KEY=
SHIOAJI_SECRET_KEY=
SHIOAJI_CA_PATH=
SHIOAJI_CA_PASSWORD=
SHIOAJI_PERSON_ID=
SHIOAJI_SIMULATION=YES
# 預設券商：yuanta 或 sinopac
BROKER=yuanta

# 本機 API 存取金鑰：保護下單/連線/風控端點。請用 python3 -c "import secrets;print(secrets.token_urlsafe(32))" 產生
# 後端讀 API_KEY，前端需在 frontend/.env 設同值的 VITE_API_KEY=...
API_KEY=

# 富果 Fugle MarketData 報價金鑰（模擬環境用真實行情）。申請：https://developer.fugle.tw/
FUGLE_API_KEY=
